# =========================================================
# AymaraContable - Variables de Entorno (EJEMPLO)
# =========================================================
#
# ⚠️ IMPORTANTE: ESTE ES UN ARCHIVO DE EJEMPLO
#
# Instrucciones:
# 1. Copiar este archivo a .env
# 2. Reemplazar los valores ficticios con tus credenciales reales
# 3. NUNCA subir el archivo .env real a GitHub
#
# =========================================================

# ---------------------------------------------------------
# BASE DE DATOS (PostgreSQL)
# ---------------------------------------------------------
# Formato: postgresql://usuario:password@host:puerto/base_de_datos
DATABASE_URL=postgresql://aymara_user:tu_password_aqui@localhost:5432/aymara_contable

# ---------------------------------------------------------
# AUTENTICACIÓN JWT
# ---------------------------------------------------------
# Clave secreta para firmar tokens JWT (mínimo 32 caracteres)
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=tu_clave_secreta_muy_larga_y_segura_cambiar_en_produccion

# Algoritmo de encriptación para JWT
ALGORITHM=HS256

# Tiempo de expiración del token en minutos (480 = 8 horas)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ---------------------------------------------------------
# URL DEL BACKEND
# ---------------------------------------------------------
# URL base de la API para CORS y referencias internas
BACKEND_URL=http://localhost:8000

# ---------------------------------------------------------
# CONFIGURACIÓN DEL SISTEMA
# ---------------------------------------------------------
# Porcentaje de IVA (0 = Monotributo, 0.21 = Responsable Inscripto)
IVA_PORCENTAJE=0

# ---------------------------------------------------------
# DIRECTORIOS
# ---------------------------------------------------------
# Directorio para archivos subidos (facturas, comprobantes)
UPLOAD_DIR=uploads

# Directorio para logs del sistema
LOGS_DIR=logs

# =========================================================
# ⚠️ SEGURIDAD - NO SUBIR .env REAL A GITHUB
# =========================================================
#
# Este archivo (.env.example) SÍ puede estar en el repositorio
# El archivo .env con valores reales NUNCA debe subirse
#
# El archivo .env está incluido en .gitignore para protección
# =========================================================
